{
  "name": "api-apostas",
  "version": "1.0.0",
  "description": "API simples de apostadores usando Node.js, Express, TypeScript e SQLite",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "selfsigned": "^5.5.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/selfsigned": "^2.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
